# Copiază ca backend/.env (NU comite .env în Git)
# Format: CHEIE=valoare (fără ghilimele, fără spații în jurul =, fără \ la final de linie)
# Încărcare: spring.config.import din application.properties (.env sau backend/.env după cwd)

RENTIX_DB_USER=root
RENTIX_DB_PASSWORD=your_mysql_password
RENTIX_JWT_SECRET=change_me_min_32_chars_random_string_here

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

RENTIX_MAIL_ENABLED=false
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=rentix@oficial.com
SPRING_MAIL_PASSWORD=your_app_password

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
